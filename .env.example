# Copy to backend/.env and frontend/.env.local as needed

# Core
NODE_ENV=development
PORT=8080
LOG_LEVEL=debug
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai102?schema=public
JWT_SECRET=dev-only-change-this-secret-min-16-chars
JWT_EXPIRES_IN=7d

# Queue (BullMQ + Redis) — document ingestion
REDIS_URL=redis://localhost:6379
INGESTION_QUEUE_ENABLED=false

# Optional Python AI sidecar (embeddings batch/RAG helpers)
# PYTHON_AI_BASE_URL=http://localhost:8000

# Azure Storage
STORAGE_PROVIDER=azure
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=documents

# Azure OpenAI
AI_PROVIDER=azure-openai
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Azure AI Search
SEARCH_PROVIDER=azure
AZURE_AI_SEARCH_ENDPOINT=
AZURE_AI_SEARCH_API_KEY=
AZURE_AI_SEARCH_INDEX=doc-chunks

# Document Intelligence
DOCUMENT_INTELLIGENCE_PROVIDER=none
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_API_KEY=

# RAG
CHUNK_SIZE=900
CHUNK_OVERLAP=150
RAG_TOP_K=8

# Azure AD B2C (optional; wire in authService when enabling)
AZURE_AD_B2C_TENANT=
AZURE_AD_B2C_POLICY=
AZURE_AD_B2C_ISSUER=
AZURE_AD_B2C_JWKS_URI=

# Frontend — browser uses same-origin /backend-api; this is for local Next route proxy fallback
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

# Next.js server-side only: proxy to backend (required in Docker / Azure — use internal URL, not localhost)
# Docker Compose sets: http://backend:8080/api
BACKEND_INTERNAL_API_URL=

# API gateway (optional Docker service on :4000)
BACKEND_URL=http://localhost:8080
