generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String      @id @default(uuid())
  tenantId  String      @unique
  name      String
  createdAt DateTime    @default(now())

  workspaces Workspace[]
}

model Workspace {
  id          String            @id @default(uuid())
  companyId   String
  tenantId    String
  slug        String
  displayName String
  industry    String            @default("general")
  domainFocus String?
  createdAt   DateTime          @default(now())

  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  members     WorkspaceMember[]
  users       User[]
  documents   Document[]
  chunks      Chunk[]
  chatSessions ChatSession[]
  chatMessages ChatMessage[]
  ingestionJobs IngestionJob[]
  workflows   Workflow[]
  workflowRuns WorkflowRun[]
  auditLogs   AuditLog[]

  @@unique([tenantId, slug])
  @@index([companyId, createdAt(sort: Desc)])
}

model WorkspaceMember {
  id          String    @id @default(uuid())
  workspaceId String
  userId      String
  role        String    @default("user")
  status      String    @default("active")
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId, createdAt(sort: Desc)])
}

model Document {
  id          String   @id @default(uuid())
  tenantId    String
  workspaceId String?
  filename    String
  contentType String
  blobUrl     String
  sizeBytes   Int
  createdAt   DateTime @default(now())

  chunks Chunk[]
  ingestionJobs IngestionJob[]
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([tenantId, filename])
}

model IngestionJob {
  id          String   @id @default(uuid())
  tenantId    String
  workspaceId String?
  documentId  String
  filename    String
  contentType String
  /// Full blob key in storage (tenant-prefixed) for async worker fetch
  storageObjectKey String?
  status      String   @default("queued")
  errorMessage String?
  attemptCount Int     @default(0)
  createdAt   DateTime @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, createdAt(sort: Desc)])
  @@index([workspaceId, status, createdAt(sort: Desc)])
  @@index([tenantId, documentId, createdAt(sort: Desc)])
}

model Chunk {
  id               String   @id @default(uuid())
  tenantId         String
  workspaceId      String?
  documentId       String
  chunkIndex       Int
  text             String
  tokenCountApprox Int
  /// Azure AI Search document id for this chunk (hybrid index)
  searchDocumentId String?
  embeddingModel   String?
  embeddedAt       DateTime?
  createdAt        DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([tenantId, documentId, chunkIndex])
  @@index([tenantId, documentId])
  @@index([workspaceId, documentId])
}

model Workflow {
  id          String   @id @default(uuid())
  tenantId    String
  workspaceId String?
  name        String
  description String?
  enabled     Boolean  @default(true)
  /// JSON: [{ "if": { "event": "document.indexed" }, "then": { "action": "notify" } }]
  rulesJson   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  runs      WorkflowRun[]

  @@index([tenantId, enabled])
  @@index([workspaceId, enabled])
}

model WorkflowRun {
  id               String   @id
  workflowId       String
  tenantId         String
  workspaceId      String?
  status           String
  triggerEvent     String
  contextJson      String
  startedAt        DateTime
  completedAt      DateTime?
  error            String?
  createdAt        DateTime @default(now())

  workflow         Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workspace        Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  steps            WorkflowRunStep[]

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([workflowId, createdAt(sort: Desc)])
}

model WorkflowRunStep {
  id               String   @id
  runId            String
  stepType         String
  status           String
  inputJson        String
  outputJson       String
  error            String?
  startedAt        DateTime
  completedAt      DateTime?
  createdAt        DateTime @default(now())

  run              WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt(sort: Desc)])
}

model AuditLog {
  id           String   @id @default(uuid())
  tenantId     String
  workspaceId  String?
  userId       String?
  action       String
  resourceType String
  resourceId   String?
  metadataJson String
  requestId    String?
  createdAt    DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([workspaceId, createdAt(sort: Desc)])
}

model ChatSession {
  id        String   @id @default(uuid())
  tenantId  String
  workspaceId String?
  userId    String
  createdAt DateTime @default(now())

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  messages ChatMessage[]

  @@index([tenantId, userId, createdAt(sort: Desc)])
  @@index([workspaceId, userId, createdAt(sort: Desc)])
}

model ChatMessage {
  id        String   @id @default(uuid())
  tenantId  String
  workspaceId String?
  sessionId String
  role      String
  content   String
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([tenantId, sessionId, createdAt(sort: Desc)])
  @@index([workspaceId, sessionId, createdAt(sort: Desc)])
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  workspaceId  String?
  email        String
  displayName  String?
  passwordHash String?
  googleSub    String?
  role         String   @default("user")
  status       String   @default("pending")
  createdAt    DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  memberships WorkspaceMember[]
  sessions ChatSession[]

  @@unique([tenantId, email])
  @@unique([tenantId, googleSub])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([workspaceId, createdAt(sort: Desc)])
}

