NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai102?schema=public

# Feature flags / limits
MAX_UPLOAD_BYTES=104857600
CHUNK_SIZE=900
CHUNK_OVERLAP=150
RAG_TOP_K=8

# Azure Blob Storage (portable via storageService)
STORAGE_PROVIDER=azure
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=documents
AZURE_STORAGE_CONNECTION_STRING=

# Azure AI Search (portable via searchService)
SEARCH_PROVIDER=azure
AZURE_AI_SEARCH_ENDPOINT=
AZURE_AI_SEARCH_API_KEY=
AZURE_AI_SEARCH_INDEX=doc-chunks

# Azure OpenAI (portable via aiService)
AI_PROVIDER=azure-openai
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Optional cache (portable via cacheService)
CACHE_PROVIDER=memory
